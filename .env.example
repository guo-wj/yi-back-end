# DeepSeek
DEEPSEEK_API_KEY=

# Redis（验证码存储）
REDIS_URL=redis://localhost:6379/0

# SMTP 邮件（发送验证码）— 以 QQ 邮箱为例，密码用「授权码」而非登录密码
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_account@qq.com
SMTP_PASSWORD=your_smtp_authorization_code
SMTP_FROM=your_account@qq.com
SMTP_FROM_NAME=易鉴
SMTP_USE_SSL=true

# 验证码策略
CODE_TTL_SECONDS=300
CODE_RESEND_SECONDS=60

# JWT 签发（生产环境务必改成随机长字符串）
JWT_SECRET=dev-secret-change-me-please-use-a-long-random-string
JWT_ALGORITHM=HS256
# 0 = 永不过期（仅用户手动退出或清除浏览器本地存储时失效）
JWT_EXPIRE_DAYS=0

# GPT-4o 视觉（掌纹/面相特征提取）
VISION_API_KEY=
VISION_API_URL=https://aigateway.edgecloudapp.com/v1/dd49a827f86db98f499afcb77642ca6b/aicenter_gpt_chat
VISION_MODEL=gpt-4o
VISION_IMAGE_DETAIL=low
PALM_FEATURE_MAX_TOKENS=380
FACE_FEATURE_MAX_TOKENS=800
VISION_MAX_OUTPUT_TOKENS=1500

# DeepSeek 文本解读
INTERPRET_MAX_TOKENS=2800
LOTTERY_INTERPRET_MAX_TOKENS=900
GUA_INTERPRET_MAX_TOKENS=1000
BAZI_INTERPRET_MAX_TOKENS=1300
PALM_INTERPRET_MAX_TOKENS=1500
FACE_INTERPRET_MAX_TOKENS=1500

# 掌纹/面相识象每日次数（测试可改大，正式环境建议 10）
PALM_EXTRACT_DAILY=20
FACE_EXTRACT_DAILY=20

# 管理后台（yi-admin）登录凭据，生产环境务必修改
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
