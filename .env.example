# DeepSeek
DEEPSEEK_API_KEY=

# Redis（验证码存储）
REDIS_URL=redis://localhost:6379/0

# SMTP 邮件（发送验证码）— 以 QQ 邮箱为例，密码用「授权码」而非登录密码
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_account@qq.com
SMTP_PASSWORD=your_smtp_authorization_code
SMTP_FROM=your_account@qq.com
SMTP_FROM_NAME=易鉴
SMTP_USE_SSL=true

# 验证码策略
CODE_TTL_SECONDS=300
CODE_RESEND_SECONDS=60

# JWT 签发（生产环境务必改成随机长字符串）
JWT_SECRET=dev-secret-change-me-please-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# SQLite 用户库
SQLITE_PATH=yi.db
